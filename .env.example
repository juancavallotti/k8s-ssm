# Copy to .env — never commit .env
#
# HuggingFace API token — required at LLM image BUILD TIME only.
# Request access to the model at: https://huggingface.co/cartesia-ai/Llamba-8B
HF_TOKEN=hf_your_token_here

# Set to "dev" to build and run with the lighter 1B model (no GPU required).
# Leave empty or unset to use the production 8B model.
# ENV=dev

# For local development, override where the chatbot backend finds the LLM service.
# Not needed when using docker compose (defaults to http://llm:8000).
# LLM_SERVICE_URL=http://localhost:8001
